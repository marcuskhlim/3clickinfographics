# --- BYOK mode (recommended for free public hosting) ---
# Leave OPENAI_API_KEY unset. Visitors paste their own key in the UI.

# --- Shared-trial mode (give visitors a few free generations on you) ---
# Set OPENAI_API_KEY to your key. Each unique IP gets INFOFORGE_FREE_GENERATIONS
# free generations using your key, then must paste their own.
# OPENAI_API_KEY=sk-...
# INFOFORGE_FREE_GENERATIONS=2

# --- Optional ---
# Image model. Default is gpt-image-1. Set to gpt-image-2 if your account has access.
# INFOFORGE_IMAGE_MODEL=gpt-image-1

# --- Optional: durable rate limit store (otherwise in-memory, resets on cold start) ---
# Create a free Vercel KV / Upstash Redis instance and paste its REST creds.
# KV_REST_API_URL=https://...upstash.io
# KV_REST_API_TOKEN=...
